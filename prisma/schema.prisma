generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  client
  consultant
  admin
  super_admin
}

enum UploadCategory {
  bloodwork
  mri
  ct_scan
  pet_scan
  pathology
  biopsy
  genomics
  microbiome
  metabolomics
  proteomics
  epigenetics
  imaging
  ecg
  sleep
  nutrition
  supplements
  medications
  symptoms
  intake_form
  insurance
  protocols
  other
}

enum ProtocolStatus {
  draft
  delivered
  updated
  archived
}

enum MessageStatus {
  sent
  delivered
  read
}

enum ConversationStatus {
  active
  archived
  closed
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
  incomplete
}

enum AuditAction {
  user_registered
  user_login
  user_logout
  user_role_changed
  upload_created
  upload_accessed
  upload_deleted
  protocol_created
  protocol_delivered
  protocol_viewed
  message_sent
  conversation_created
  subscription_created
  subscription_updated
  payment_succeeded
  payment_failed
  admin_impersonation
  consent_signed
  settings_changed
}

// ─── Core Entities ────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  clerkId         String    @unique
  email           String    @unique
  name            String?
  avatarUrl       String?
  role            UserRole  @default(client)
  onboardingDone  Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  profile                 ClientProfile?
  uploads                 Upload[]
  protocols               Protocol[]        @relation("ClientProtocols")
  deliveredProtocols      Protocol[]        @relation("DeliveredByConsultant")
  clientConversations     Conversation[]    @relation("ClientConversations")
  staffConversations      Conversation[]    @relation("StaffConversations")
  sentMessages            Message[]
  biomarkerLogs           BiomarkerLog[]
  symptomLogs             SymptomLog[]
  timelineEvents          TimelineEvent[]
  subscriptions           Subscription[]
  invoices                Invoice[]
  auditLogs               AuditLog[]
  consentRecords          ConsentRecord[]
  consultantAssignments   ConsultantAssignment[] @relation("ConsultantAssignments")
  clientAssignments       ConsultantAssignment[] @relation("ClientAssignments")
  activityLogs            ActivityLog[]
  notifications           Notification[]
  adminNotesAsClient      AdminNote[]    @relation("ClientAdminNotes")
  adminNotesAsAuthor      AdminNote[]    @relation("AuthorAdminNotes")

  @@map("users")
}

model ClientProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalName       String?
  dateOfBirth     DateTime?
  phone           String?
  address         String?
  city            String?
  province        String?
  country         String?   @default("Canada")
  postalCode      String?
  emergencyName   String?
  emergencyPhone  String?
  healthGoals     String?
  medicalHistory  String?
  currentMeds     String?
  allergies       String?
  biologicalAge   Int?
  hrvScore        Int?
  inflammationStatus String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("client_profiles")
}

model Upload {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName        String
  originalName    String
  mimeType        String
  sizeBytes       Int
  category        UploadCategory
  storageKey      String          @unique
  storageUrl      String
  sha256Hash      String
  isEncrypted     Boolean         @default(true)
  isImmutable     Boolean         @default(true)
  uploadedAt      DateTime        @default(now())
  accessedAt      DateTime?
  archivedAt      DateTime?
  archivedById    String?
  notes           String?

  // Attribution / audit
  createdByUserId String?
  createdByRole   String?
  createdByName   String?
  updatedByUserId String?
  updatedByRole   String?

  @@index([userId])
  @@index([category])
  @@index([archivedAt])
  @@index([createdByUserId])
  @@map("uploads")
}

model Protocol {
  id              String          @id @default(cuid())
  clientId        String
  client          User            @relation("ClientProtocols", fields: [clientId], references: [id])
  deliveredById   String?
  deliveredBy     User?           @relation("DeliveredByConsultant", fields: [deliveredById], references: [id])
  title           String
  status          ProtocolStatus  @default(draft)
  currentVersion  Int             @default(1)
  deliveredAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Attribution / audit
  createdByUserId String?
  createdByRole   String?
  createdByName   String?
  updatedByUserId String?
  updatedByRole   String?
  updatedByName   String?

  versions        ProtocolVersion[]
  timelineEvents  TimelineEvent[]

  @@index([clientId])
  @@index([createdByUserId])
  @@map("protocols")
}

model ProtocolVersion {
  id              String    @id @default(cuid())
  protocolId      String
  protocol        Protocol  @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  version         Int
  content         String    @db.Text
  pdfStorageKey   String?
  pdfUrl          String?
  notes           String?
  createdAt       DateTime  @default(now())

  // Attribution / audit
  createdByUserId String?
  createdByRole   String?
  createdByName   String?

  @@unique([protocolId, version])
  @@index([protocolId])
  @@map("protocol_versions")
}

model Conversation {
  id              String              @id @default(cuid())
  clientId        String
  client          User                @relation("ClientConversations", fields: [clientId], references: [id])
  staffId         String
  staff           User                @relation("StaffConversations", fields: [staffId], references: [id])
  subject         String?
  status          ConversationStatus  @default(active)
  lastMessageAt   DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  messages        Message[]

  @@index([clientId])
  @@index([staffId])
  @@map("conversations")
}

model Message {
  id              String          @id @default(cuid())
  conversationId  String
  conversation    Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User            @relation(fields: [senderId], references: [id])
  body            String          @db.Text
  status          MessageStatus   @default(sent)
  attachmentKey   String?
  attachmentUrl   String?
  attachmentName  String?
  isImmutable     Boolean         @default(true)
  createdAt       DateTime        @default(now())
  readAt          DateTime?

  // Attribution snapshot (immutable at send time)
  senderRole      String?
  senderName      String?

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model BiomarkerLog {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  panel           String
  marker          String
  value           Float
  unit            String
  referenceMin    Float?
  referenceMax    Float?
  isAbnormal      Boolean   @default(false)
  loggedAt        DateTime
  source          String?
  notes           String?
  createdAt       DateTime  @default(now())

  // Attribution / audit
  createdByUserId String?
  createdByRole   String?
  createdByName   String?

  @@index([userId])
  @@index([loggedAt])
  @@map("biomarker_logs")
}

model SymptomLog {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptom         String
  severity        Int       // 1-10
  notes           String?
  loggedAt        DateTime
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@map("symptom_logs")
}

model TimelineEvent {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  protocolId      String?
  protocol        Protocol? @relation(fields: [protocolId], references: [id])
  eventType       String
  title           String
  description     String?   @db.Text
  occurredAt      DateTime
  createdAt       DateTime  @default(now())

  // Attribution / audit
  createdByUserId String?
  createdByRole   String?
  createdByName   String?

  @@index([userId])
  @@index([occurredAt])
  @@index([createdByUserId])
  @@map("timeline_events")
}

model Subscription {
  id                      String              @id @default(cuid())
  userId                  String
  user                    User                @relation(fields: [userId], references: [id])
  stripeCustomerId        String?
  stripeSubscriptionId    String?             @unique
  stripePriceId           String?
  status                  SubscriptionStatus  @default(active)
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean             @default(false)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  invoices                Invoice[]

  @@index([userId])
  @@map("subscriptions")
}

model Invoice {
  id                      String    @id @default(cuid())
  userId                  String
  user                    User      @relation(fields: [userId], references: [id])
  subscriptionId          String?
  subscription            Subscription? @relation(fields: [subscriptionId], references: [id])
  stripeInvoiceId         String?   @unique
  stripePaymentIntentId   String?
  amountCents             Int
  currency                String    @default("cad")
  status                  String
  description             String?
  paidAt                  DateTime?
  createdAt               DateTime  @default(now())

  @@index([userId])
  @@map("invoices")
}

model AuditLog {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  action          AuditAction
  resourceType    String?
  resourceId      String?
  metadata        Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  action          String
  description     String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@map("activity_logs")
}

model ConsentRecord {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  documentType    String
  documentVersion String
  signedAt        DateTime  @default(now())
  ipAddress       String?

  @@unique([userId, documentType])
  @@map("consent_records")
}

model ConsultantAssignment {
  id              String    @id @default(cuid())
  consultantId    String
  consultant      User      @relation("ConsultantAssignments", fields: [consultantId], references: [id])
  clientId        String
  client          User      @relation("ClientAssignments", fields: [clientId], references: [id])
  assignedAt      DateTime  @default(now())
  notes           String?

  @@unique([consultantId, clientId])
  @@map("consultant_assignments")
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  body        String?   @db.Text
  isRead      Boolean   @default(false)
  readAt      DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model AdminNote {
  id          String    @id @default(cuid())
  clientId    String
  client      User      @relation("ClientAdminNotes", fields: [clientId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation("AuthorAdminNotes", fields: [authorId], references: [id])
  note        String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@map("admin_notes")
}
